---
// The Local Angle "A" mark, traced from the original logo.
const { size = 20 } = Astro.props;
---
<svg
  class="mark"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 327 271"
  width={size}
  height={Math.round(size * (271 / 327))}
  aria-hidden="true"
>
  <path fill="#2b8987" stroke="#2b8987" stroke-width="6" stroke-linejoin="round" d="M105 96 L162 188 L106 268 L6 268 Z"></path>
  <path fill="#fe6962" stroke="#fe6962" stroke-width="6" stroke-linejoin="round" d="M164 4 L322 268 L219 268 L107 93 Z"></path>
</svg>
